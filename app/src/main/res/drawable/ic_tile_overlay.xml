        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M3,4 L15,4 L15,14 L3,14 Z M5,6 L5,12 L13,12 L13,6 Z" />
    <path
        android:fillColor="#FFFFFFFF"
