<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <FrameLayout
        android:id="@+id/fw_action"
        android:layout_width="42dp"
        android:layout_height="27dp"
        android:background="@drawable/fw_fps_watch_bg">

        <TextView
            android:id="@+id/fw_fps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-black"
            android:text="FPS"
            android:textAlignment="center"
            android:textColor="#e3e3e3"
            android:textSize="12dp" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/fw_fps_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/fw_action"
        android:layout_marginTop="2dp"
        android:background="@drawable/shape_corner"
        android:orientation="vertical"
        android:paddingVertical="4dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:text="@string/fps_duration"
            android:textColor="#ffffff"
            android:textSize="9dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:layout_marginHorizontal="6dp"
            android:layout_marginVertical="4dp"
            android:background="#cccccccc" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/duration_5m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:alpha="0.3"
                android:paddingHorizontal="4dp"
                android:text="5"
                android:textColor="#ffffff"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/duration_10m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:alpha="0.3"
                android:paddingHorizontal="4dp"
                android:text="10"
                android:textColor="#ffffff"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/duration_15m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:alpha="0.3"
                android:paddingHorizontal="4dp"
                android:text="15"
                android:textColor="#ffffff"
                android:textSize="11dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/duration_30m"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:alpha="0.3"
                android:paddingHorizontal="4dp"
                android:text="30"
                android:textColor="#ffffff"
                android:textSize="11dp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
