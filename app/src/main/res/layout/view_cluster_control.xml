<?xml version="1.0" encoding="utf-8"?>
<!-- Inflated 3 times (little/big/prime) from FreqControlActivity. IDs are
     reused across each copy without collision, since findViewById is always
     called on the root of one specific inflated copy, not on the Activity. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginBottom="16dp">

    <TextView
        android:id="@+id/cluster_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        tools:text="Little (policy0)" />

    <TextView
        android:id="@+id/cluster_current_freq"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="14dp"
        tools:text="cur: 1420 MHz" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_governor_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/spinner_governor"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_min_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/spinner_min_freq"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_max_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/spinner_max_freq"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

</LinearLayout>
