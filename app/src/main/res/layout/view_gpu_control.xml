<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginBottom="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/freq_gpu_title"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/gpu_current_freq"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="14dp"
        tools:text="cur: 587 MHz" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_governor_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/gpu_spinner_governor"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_min_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/gpu_spinner_min_freq"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_max_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/gpu_spinner_max_freq"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_adreno_boost_label"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <Spinner
        android:id="@+id/gpu_spinner_adreno_boost"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card"
        android:popupBackground="@drawable/bg_card"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_pwrlevel_title"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/gpu_pwrlevel_bounds"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp"
        tools:text="pwrlevel: min=7 max=0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/freq_pwrlevel_default"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/gpu_default_pwrlevel_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textStyle="bold"
        android:textSize="13sp"
        android:layout_marginBottom="4dp"
        tools:text="3" />

    <SeekBar
        android:id="@+id/gpu_seekbar_default_pwrlevel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/freq_gpu_throttling_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/switch_gpu_throttling"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

</LinearLayout>
