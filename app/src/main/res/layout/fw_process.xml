<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:alpha="0.92"
    android:background="@drawable/fw_process_bg"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/fw_float_pin"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:alpha="0.3"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/dialog_pin" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/process_monitor_title"
            android:textColor="@color/text_primary"
            android:textSize="11dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/process_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="2dp"
            android:text="@string/process_filter_apps"
            android:textColor="@color/text_secondary"
            android:textSize="11dp" />

        <ImageButton
            android:id="@+id/fw_float_minimize"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="@android:color/transparent"
            android:padding="5dp"
            android:scaleType="fitCenter"
            android:src="@drawable/dialog_minimize" />

        <ImageButton
            android:id="@+id/fw_float_close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="2dp"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@drawable/dialog_close" />
    </LinearLayout>

    <ListView
        android:id="@+id/process_list"
        android:layout_width="155dp"
        android:layout_height="170dp"
        android:layout_marginBottom="6dp"
        android:divider="@null"
        android:fastScrollAlwaysVisible="false"
        android:fastScrollEnabled="false" />
</LinearLayout>
